      "min_price_ratio": 0.8
    },
    "ITEM_ID_HERE": {
      "name": "iPhone 15 Pro 256G",
      "strategy": "phone",
      "condition_note": "95新，无划痕，电池健康92%",
      "shipping_note": "顺丰包邮",
      "listed_price": 5800,
      "floor_price": 5000,
